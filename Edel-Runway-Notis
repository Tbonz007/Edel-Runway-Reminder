<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Edel Runway — Listing Call Reminders</title>
<meta name="theme-color" content="#041914">
<link rel="manifest" href="manifest.webmanifest">
<link rel="icon" href="icon-192.png">
<link rel="apple-touch-icon" href="icon-192.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<!-- Manrope stands in for Alcyone (Medium 500 / Light 300) since Alcyone is a
     licensed foundry face not available on a free CDN. Swap the @import below
     for Alcyone's own webfont kit if/when you have a license + hosted files. -->
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --abyss:#041914;
    --dark-pine:#234038;
    --medium-pine:#2DA68A;
    --light-pine:#8BFBD5;
    --text:#EAF5F1;
    --muted:#7FA79A;
    --ring-track:#16302A;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:
      radial-gradient(60% 50% at 50% 0%, rgba(45,166,138,.14) 0%, transparent 60%),
      var(--abyss);
    color:var(--text);
    font-family:'Manrope',system-ui,sans-serif;
    font-weight:300;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:32px 20px 44px;
  }

  .brand{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:22px;
  }
  .brand img{width:26px; height:26px;}
  .brand span{
    font-weight:600;
    font-size:15px;
    letter-spacing:.03em;
  }
  .brand span em{
    font-style:normal;
    color:var(--medium-pine);
  }

  .hero{
    text-align:center;
    max-width:420px;
    margin-bottom:30px;
  }
  h1{
    font-family:'Manrope',sans-serif;
    font-weight:500;
    font-size:27px;
    line-height:1.25;
    margin:0 0 12px;
    letter-spacing:-.01em;
  }
  h1 em{
    font-style:normal;
    color:var(--light-pine);
  }
  .hero p{
    font-weight:300;
    font-size:14.5px;
    line-height:1.6;
    color:var(--muted);
    margin:0;
  }

  .ring-wrap{
    position:relative;
    width:250px;
    height:250px;
    margin:6px 0 26px;
  }
  svg{transform:rotate(-90deg);}
  .track{stroke:var(--ring-track); fill:none; stroke-width:10;}
  .progress{
    stroke:var(--medium-pine);
    fill:none;
    stroke-width:10;
    stroke-linecap:round;
    transition:stroke-dashoffset 1s linear, stroke .3s;
    filter:drop-shadow(0 0 6px rgba(139,251,213,.35));
  }
  .progress.paused{stroke:var(--muted); filter:none;}
  .ring-center{
    position:absolute; inset:0;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    gap:8px;
  }
  .mark{
    width:34px;
    height:34px;
    opacity:.9;
    transition:transform 1.4s ease-in-out, opacity .3s;
  }
  .mark.pulsing{
    animation:pulse 2.6s ease-in-out infinite;
  }
  @keyframes pulse{
    0%,100%{transform:scale(1) rotate(0deg); opacity:.85;}
    50%{transform:scale(1.12) rotate(8deg); opacity:1;}
  }
  .time-left{
    font-family:'Manrope',serif;
    font-size:32px;
    font-weight:600;
    font-variant-numeric:tabular-nums;
    letter-spacing:-.01em;
  }
  .time-label{font-size:11px; color:var(--muted); letter-spacing:.1em; text-transform:uppercase;}

  .card{
    background:linear-gradient(180deg, rgba(35,64,56,.55), rgba(35,64,56,.28));
    border:1px solid #2C4A41;
    border-radius:18px;
    padding:22px;
    width:100%;
    max-width:380px;
    margin-bottom:16px;
    backdrop-filter:blur(6px);
  }
  .card h2{
    font-size:11.5px;
    letter-spacing:.12em;
    text-transform:uppercase;
    color:var(--muted);
    margin:0 0 14px;
    font-weight:600;
  }
  .presets{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
    margin-bottom:14px;
  }
  .preset-btn{
    flex:1 1 auto;
    background:#0D2B22;
    border:1px solid #2C4A41;
    color:var(--text);
    padding:12px 10px;
    border-radius:12px;
    font-size:14px;
    font-weight:500;
    font-family:'Manrope';
    cursor:pointer;
    transition:all .15s;
    min-width:100px;
  }
  .preset-btn:hover{border-color:var(--medium-pine);}
  .preset-btn.active{
    background:linear-gradient(135deg,var(--medium-pine),#1F8A72);
    border-color:transparent;
    color:#041914;
    font-weight:700;
  }
  .custom-row{
    display:flex;
    align-items:center;
    gap:10px;
    background:#071F19;
    border:1px solid #2C4A41;
    border-radius:12px;
    padding:10px 14px;
  }
  .custom-row label{font-size:13px; color:var(--muted); white-space:nowrap;}
  .custom-row input[type=number]{
    width:56px;
    background:transparent;
    border:none;
    color:var(--text);
    font-size:16px;
    font-family:'Manrope';
    text-align:center;
    -moz-appearance:textfield;
  }
  .custom-row input::-webkit-outer-spin-button,
  .custom-row input::-webkit-inner-spin-button{-webkit-appearance:none; margin:0;}
  .custom-row span.unit{color:var(--muted); font-size:13px;}
  .custom-row button{
    margin-left:auto;
    background:none;
    border:1px solid var(--light-pine);
    color:var(--light-pine);
    padding:8px 14px;
    border-radius:9px;
    font-size:13px;
    font-weight:600;
    font-family:'Manrope';
    cursor:pointer;
  }
  .custom-row button:hover{background:var(--light-pine); color:#041914;}

  .controls{
    display:flex;
    gap:10px;
    width:100%;
    max-width:380px;
    margin-bottom:16px;
  }
  .btn{
    flex:1;
    padding:15px;
    border-radius:14px;
    border:none;
    font-size:15px;
    font-weight:700;
    font-family:'Manrope';
    cursor:pointer;
    transition:transform .1s, opacity .15s;
  }
  .btn:active{transform:scale(.97);}
  .btn-start{background:linear-gradient(135deg,var(--medium-pine),#1F8A72); color:#041914;}
  .btn-stop{background:#0D2B22; color:var(--text); border:1px solid #2C4A41;}
  .btn:disabled{opacity:.4; cursor:not-allowed;}

  .status{
    font-size:13px;
    color:var(--muted);
    text-align:center;
    max-width:380px;
    line-height:1.5;
  }
  .status.ok{color:var(--light-pine);}
  .status.warn{color:#F4C77A;}

  .footer-note{
    margin-top:30px;
    font-size:11.5px;
    color:#4E6E64;
    text-align:center;
    max-width:340px;
    line-height:1.7;
  }

  .credit{
    margin-top:14px;
    font-size:11px;
    color:#3A5A50;
    letter-spacing:.04em;
    text-align:center;
  }

  #enable-btn{
    background:none;
    border:1px solid var(--medium-pine);
    color:var(--medium-pine);
    padding:10px 18px;
    border-radius:11px;
    font-size:13px;
    font-weight:600;
    font-family:'Manrope';
    cursor:pointer;
    margin-top:10px;
  }
</style>
</head>
<body>

  <div class="brand">
    <img src="icon-192.png" alt="Edel mark">
    <span>Edel <em>Runway</em></span>
  </div>

  <div class="hero">
    <h1>Don't Miss the Next <em>Listing Call</em></h1>
    <p>Set your reminder interval, add this to your home screen, and turn on notifications. No login, no Desk Profile — just a nudge when it's time to check Runway.</p>
  </div>

  <div class="ring-wrap">
    <svg width="250" height="250" viewBox="0 0 250 250">
      <circle class="track" cx="125" cy="125" r="110"></circle>
      <circle id="progress-circle" class="progress" cx="125" cy="125" r="110"
        stroke-dasharray="691.15" stroke-dashoffset="0"></circle>
    </svg>
    <div class="ring-center">
      <img src="icon-192.png" class="mark" id="mark" alt="">
      <div class="time-left" id="time-left">1:30:00</div>
      <div class="time-label" id="ring-status">ready</div>
    </div>
  </div>

  <div class="card">
    <h2>Reminder interval</h2>
    <div class="presets">
      <button class="preset-btn active" data-min="90">1h 30m</button>
      <button class="preset-btn" data-min="75">1h 15m</button>
    </div>
    <div class="custom-row">
      <label for="custom-h">Custom</label>
      <input type="number" id="custom-h" min="0" max="12" value="0" placeholder="0">
      <span class="unit">h</span>
      <input type="number" id="custom-m" min="0" max="59" value="45" placeholder="0">
      <span class="unit">min</span>
      <button id="set-custom">Set</button>
    </div>
  </div>

  <div class="controls">
    <button class="btn btn-start" id="start-btn">Start</button>
    <button class="btn btn-stop" id="stop-btn" disabled>Stop</button>
  </div>

  <div class="status" id="status">Notifications not enabled yet.<br>
    <button id="enable-btn">Enable notifications</button>
  </div>

  <div class="footer-note">
    An unofficial companion reminder — not affiliated with or endorsed by Edel.
    Runs while this app is open (foreground or installed). If Android fully
    closes it after a long time locked, reopen it to resume.
  </div>

  <div class="credit">Created by EdDefi</div>

<script>
const PRESET_BTNS = document.querySelectorAll('.preset-btn');
const customH = document.getElementById('custom-h');
const customM = document.getElementById('custom-m');
const setCustomBtn = document.getElementById('set-custom');
const startBtn = document.getElementById('start-btn');
const stopBtn = document.getElementById('stop-btn');
const enableBtn = document.getElementById('enable-btn');
const statusEl = document.getElementById('status');
const timeLeftEl = document.getElementById('time-left');
const ringStatusEl = document.getElementById('ring-status');
const progressCircle = document.getElementById('progress-circle');
const markEl = document.getElementById('mark');

const CIRC = 2 * Math.PI * 110; // 691.15

let intervalSeconds = 90 * 60;
let remaining = intervalSeconds;
let timerId = null;
let running = false;

function fmt(sec){
  const h = Math.floor(sec/3600);
  const m = Math.floor((sec%3600)/60);
  const s = sec%60;
  if(h > 0) return `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  return `${m}:${String(s).padStart(2,'0')}`;
}

function updateRing(){
  timeLeftEl.textContent = fmt(remaining);
  const frac = remaining / intervalSeconds;
  progressCircle.style.strokeDashoffset = CIRC * (1 - frac);
}

function setInterval_(minutes, activeBtn){
  intervalSeconds = Math.max(60, Math.round(minutes * 60));
  remaining = intervalSeconds;
  PRESET_BTNS.forEach(b => b.classList.remove('active'));
  if(activeBtn) activeBtn.classList.add('active');
  updateRing();
}

PRESET_BTNS.forEach(btn => {
  btn.addEventListener('click', () => {
    setInterval_(Number(btn.dataset.min), btn);
  });
});

setCustomBtn.addEventListener('click', () => {
  const h = Number(customH.value) || 0;
  const m = Number(customM.value) || 0;
  const total = h * 60 + m;
  if(total <= 0){
    statusEl.textContent = 'Enter a duration greater than 0.';
    statusEl.className = 'status warn';
    return;
  }
  setInterval_(total, null);
  statusEl.textContent = `Custom interval set: ${h}h ${m}m.`;
  statusEl.className = 'status';
});

function requestPermission(){
  if(!('Notification' in window)){
    statusEl.textContent = 'This browser does not support notifications.';
    statusEl.className = 'status warn';
    return;
  }
  Notification.requestPermission().then(perm => {
    if(perm === 'granted'){
      statusEl.textContent = 'Notifications enabled. You can start your timer.';
      statusEl.className = 'status ok';
      enableBtn.style.display = 'none';
    } else {
      statusEl.textContent = 'Notifications blocked. Enable them in your browser/site settings to get reminders.';
      statusEl.className = 'status warn';
    }
  });
}
enableBtn.addEventListener('click', requestPermission);

if('Notification' in window && Notification.permission === 'granted'){
  statusEl.textContent = 'Notifications enabled. You can start your timer.';
  statusEl.className = 'status ok';
  enableBtn.style.display = 'none';
}

function fireNotification(){
  const title = 'Check Edel Runway';
  const opts = {
    body: `Your ${fmt(intervalSeconds)} interval is up — time to check for active Listing Calls.`,
    icon: 'icon-192.png',
    badge: 'icon-192.png',
    tag: 'runway-reminder',
    renotify: true,
    vibrate: [200,80,200]
  };
  if(navigator.serviceWorker && navigator.serviceWorker.controller){
    navigator.serviceWorker.ready.then(reg => reg.showNotification(title, opts));
  } else if('Notification' in window && Notification.permission === 'granted'){
    new Notification(title, opts);
  }
  try{
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const o = ctx.createOscillator();
    const g = ctx.createGain();
    o.connect(g); g.connect(ctx.destination);
    o.frequency.value = 880;
    g.gain.setValueAtTime(0.15, ctx.currentTime);
    o.start();
    o.stop(ctx.currentTime + 0.35);
  }catch(e){}
}

function tick(){
  remaining -= 1;
  if(remaining <= 0){
    fireNotification();
    remaining = intervalSeconds;
  }
  updateRing();
}

function start(){
  if(running) return;
  if(!('Notification' in window) || Notification.permission !== 'granted'){
    requestPermission();
  }
  running = true;
  remaining = intervalSeconds;
  updateRing();
  progressCircle.classList.remove('paused');
  markEl.classList.add('pulsing');
  ringStatusEl.textContent = 'running';
  startBtn.disabled = true;
  stopBtn.disabled = false;
  timerId = setInterval(tick, 1000);
}

function stop(){
  running = false;
  clearInterval(timerId);
  timerId = null;
  remaining = intervalSeconds;
  updateRing();
  progressCircle.classList.add('paused');
  markEl.classList.remove('pulsing');
  ringStatusEl.textContent = 'ready';
  startBtn.disabled = false;
  stopBtn.disabled = true;
}

startBtn.addEventListener('click', start);
stopBtn.addEventListener('click', stop);

updateRing();

if('serviceWorker' in navigator){
  navigator.serviceWorker.register('sw.js').catch(() => {});
}

window.addEventListener('beforeinstallprompt', (e) => {
  e.preventDefault();
  window.deferredPrompt = e;
});
</script>
</body>
</html>
